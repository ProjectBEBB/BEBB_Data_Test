      <addrLine>A Monsieur</addrLine>
      <addrLine>Monsieur Bernoulli</addrLine>
      <addrLine>at <abbr>M<supplied>.</supplied><hi rend="sup">rs</hi></abbr> Benoit, house</addrLine>
      <addrLine>in Suffolk street</addrLine>
      <addrLine>near charing cross</addrLine>
      <addrLine>London</addrLine>
    </address>
  </closer>
