<body>
<div type="letter">
    <pb facs="3698513" n="1"/>
<opener>
  <dateline><lb/><rs key="place_GEO-2988507" type="place"><choice><orig>paris</orig><reg>Paris</reg></choice></rs> le <date when="1745-12-27">27. decembre 1745</date></dateline> 
</opener>
<opener>
    <salute><lb/>Monsieur</salute>
</opener>
<p>
    <lb/>J’ay <choice><orig>recu</orig><reg>reçu</reg></choice> l’honneur de Vostre <rs type="letter">Lettre</rs>, M.<hi rend="sup">e</hi>
    <lb/><rs key="pers_DE-588-118681028" type="person">du <choice><orig>chatelet</orig><reg>Chatelet</reg></choice></rs> pouvoit bien Vous mander
  <lb/>qu’elle m’avoit envoyé 34<hi rend="sup">lb</hi><!-- Währungszeichen für livres --> 7 <abbr>s</abbr><!-- Währungszeichen für Sols --> 56 <abbr>d</abbr><!-- Währungszeichen für deniers --> que vous
  <lb/><choice><orig>Joindrès</orig><reg>joindrés</reg></choice> au 246<hi rend="sup">lb</hi><!-- Währungszeichen für livre --> 2 <abbr>s</abbr><!-- Währungszeichen für Sols --> que <choice><orig>Je</orig><reg>je</reg></choice> vous ay mandé
    <lb/>Vous devoir ou <choice><orig>a</orig><reg>à</reg></choice> <abbr>M.</abbr> Vostre <rs key="pers_DE-588-117589136" type="person">frere</rs><supplied>.</supplied> Cela fait
  <lb/>280<hi rend="sup">lb</hi><!-- Währungszeichen für livres --> 9 <abbr>s</abbr><!-- Währungszeichen für Sols --> 6<choice><orig><g ref="#ndot">.</g></orig><reg></reg></choice> <abbr>d</abbr><!-- Währungszeichen für deniers --> et <choice><orig>Les</orig><reg>les</reg></choice> tirerés sur moy <add><choice><orig>a</orig><reg>à</reg></choice> <del><gap/></del>deux jours de date</add> pour
  <lb/>demeurer quites <choice><orig>Jusqu</orig><reg>jusqu</reg></choice>’<choice><orig>a</orig><reg>à</reg></choice> ce <choice><orig>Jour</orig><reg>jour</reg></choice><choice><orig>,</orig><reg>.</reg></choice> Les six
    <lb/>premiers mois de la tontine de <abbr>M.</abbr> Vostre
    <lb/><rs key="pers_DE-588-118509969" type="person">pere</rs> etant <choice><orig>Compris</orig><reg>compris</reg></choice>, <choice><orig>Comme</orig><reg>comme</reg></choice> Vous le pouvés voir
    <lb/>par le petit <choice><orig>Compte</orig><reg>compte</reg></choice> qui est dans <choice><orig>La</orig><reg>la</reg></choice> <rs type="letter">lettre</rs>
  <lb/>de <abbr>M.</abbr> Vostre <rs key="pers_DE-588-117589136" type="person">frere</rs><choice><orig>,</orig><reg>.</reg></choice> Je ne manqueray pas
  <lb/>de dire <choice><orig>a</orig><reg>à</reg></choice> mon <rs type="person">fils</rs> que Vous Vous souvenés
  <lb/>de luy<choice><orig>,</orig><reg>.</reg></choice> Il <unclear reason="illegible">est</unclear> bien agreablement auprés du
  <lb/><rs key="pers_DE-588-118535749" type="person">roy</rs> et de<unclear reason="illegible">s</unclear> Reynes<choice><orig>,</orig><reg>.</reg></choice> J’ay l’honneur d<supplied>’</supplied>estre
    <lb/>avec respect<supplied>,</supplied>
  <lb/>Monsieur<supplied>,</supplied>
</p> 
<closer>
    <salute>
        <lb/>Vostre tres humble
        <lb/>et tres obeisant serviteur
    </salute>
    <signed>
      <lb/><rs key="pers_DE-588-1156356024" type="person">Moreau de Maupertuis</rs>
    </signed>
</closer>
    <pb facs="3698514" n="2" type="empty"/>
</div>
