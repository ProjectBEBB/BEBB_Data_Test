            <addrLine>A Monsieur</addrLine>
            <addrLine>Monsieur Bernoulli</addrLine>
            <addrLine>très celebre Professeur en</addrLine>
            <addrLine>Matematique</addrLine>
            <addrLine>a Bale</addrLine><note hand="unknown">Ropras, Juin 1752.</note></address>
